{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",
  
  "AppSettings": {
    "AllowedOrigins": [ "https://example.com", "https://another.example" ],
    "RateLimit": {
      "ReadPermitLimit": 30,
      "WritePermitLimit": 5,
      "WindowInSeconds": 60
    },
    
    "Mode": "Development"
  }
}